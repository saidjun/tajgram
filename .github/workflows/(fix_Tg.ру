name: Tajgram Factory Fixer

on:
  workflow_dispatch: # Барои дастӣ иҷро кардан

permissions:
  contents: write

jobs:
  factory-fixer:
    runs-on: ubuntu-latest
    steps:
      - name: 📥 Гирифтани код
        uses: actions/checkout@v4

      - name: 🛠️ Иҷрои Ҷарроҳии Амиқ
        run: |
          python3 -c "
          import xml.etree.ElementTree as ET
          import os

          # Суроғаи дақиқ
          input_file = 'TMessagesProj/src/main/res/values-tg/strings.xml'
          output_file = 'strings_fixed_master.xml'
          
          if not os.path.exists(input_file):
              print('❌ Файл ёфт нашуд!')
              exit(1)

          tree = ET.parse(input_file)
          root = tree.getroot()
          
          # Ҷарроҳии амиқ барои ҳар як сатр
          for elem in root.findall('string'):
              if elem.text:
                  text = elem.text
                  # Ислоҳи заводӣ: /n/ -> \n, ' -> \', " -> \"
                  text = text.replace('/n/', '\n').replace('/n', '\n')
                  text = text.replace(\"\\\\'\", \"'\").replace('\\\\\"', '\"')
                  text = text.replace(\"'\", \"\\\\'\").replace('\"', '\\\\\"')
                  
                  # Ислоҳи амперсанд
                  if '&' in text and '&amp;' not in text:
                      text = text.replace('&', '&amp;')
                      
                  elem.text = text
          
          tree.write(output_file, encoding='utf-8', xml_declaration=True)
          print('✅ Файли заводӣ омода шуд!')
          "

      - name: 🚀 Сабт дар папкаи асосӣ (Главный)
        run: |
          git config --global user.name "Tajgram Factory Bot"
          git config --global user.email "bot@tajgram.com"
          git add strings_fixed_master.xml
          git commit -m "Автоматики: Файли strings_fixed_master.xml ислоҳ шуд"
          git push origin HEAD:${{ github.ref_name }} --force
