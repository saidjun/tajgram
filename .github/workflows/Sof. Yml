name: Tajgram XML Shield

on:
  push:
    branches:
      - main
  pull_request:
    branches:
      - main
  workflow_dispatch: # 👈 ИН ТУГМАИ "RUN"-РО ДАСТӢ ПАЙДО МЕКУНАД!

jobs:
  clean_xml:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Fix XML Tokens with Linux Sed
        run: |
          FILE_PATH="TMessagesProj/src/main/res/values-tg/strings.xml"
          if [ -f "$FILE_PATH" ]; then
            echo "🚀 Оғози тозакунии заводии файл бо фармонҳои Linux..."
            
            # 1. Иваз кардани нохунакҳо дар name
            sed -i 's/name=&quot;/name="/g' "$FILE_PATH"
            sed -i 's/name=&amp;quot;/name="/g' "$FILE_PATH"
            
            # 2. Иваз кардани тегҳо ва коваҳо
            sed -i 's/&quot;>/">/g' "$FILE_PATH"
            sed -i 's/&amp;quot;>/">/g' "$FILE_PATH"
            sed -i 's/&quot;\/>/"\/>/g' "$FILE_PATH"
            sed -i 's/&amp;quot;\/>/"\/>/g' "$FILE_PATH"
            
            echo "✅ Аломатҳо хаматарафа соз ва тоза шуданд!"
          else
            echo "❌ Файл ёфт нашуд!"
          fi

      - name: Commit and Push Changes
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add TMessagesProj/src/main/res/values-tg/strings.xml
          git diff --quiet && git diff --staged --quiet || (git commit -m "🚀 Заводи Мутлақ: Аломатҳои XML хаматарафа соз шуданд" && git push)
